# ════════════════════════════════════════════════════════════════
#  ERP FINCAS - Environment Configuration
#  Copia este archivo a .env y ajusta los valores para tu entorno
# ════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false

# ── Domain ───────────────────────────────────────────────────────
BASE_DOMAIN=nanoserver.es

# ── Database ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=erp_fincas
DB_USER=erp_user
DB_PASS=CAMBIA_ESTA_PASSWORD

# ── Mail (SMTP) ──────────────────────────────────────────────────
MAIL_HOST=smtp.nanoserver.es
MAIL_PORT=587
MAIL_USERNAME=noreply@nanoserver.es
MAIL_PASSWORD=CAMBIA_ESTA_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM=noreply@nanoserver.es
MAIL_FROM_NAME=ERP Fincas

# ── Security ─────────────────────────────────────────────────────
# Genera con: php -r "echo bin2hex(random_bytes(16));"
ENCRYPTION_KEY=GENERA_UNA_CLAVE_ALEATORIA_DE_32_CARACTERES
